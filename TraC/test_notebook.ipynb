   "source": [
    "# ============================================================\n",
    "#   TRAJECTORY ANALYSIS & PLOTTING MODULE FOR OFFLINE RL\n",
    "# ============================================================\n",
    "\n",
    "import h5py\n",
    "import numpy as np\n",
    "import seaborn as sns\n",
    "import matplotlib.pyplot as plt\n",
    "import pandas as pd\n",
    "\n",
    "sns.set(style=\"whitegrid\")\n",
    "\n",
    "# ============================================================\n",
    "#   1. LOAD DATASET (DSRL-format HDF5)\n",
    "# ============================================================\n",
    "\n",
    "def load_dsrl(path):\n",
    "    \"\"\"Loads a DSRL HDF5 dataset and returns a dictionary.\"\"\"\n",
    "    with h5py.File(path, \"r\") as f:\n",
    "        data = {\n",
    "            \"obs\": np.array(f[\"observations\"]),\n",
    "            \"next_obs\": np.array(f[\"next_observations\"]),\n",
    "            \"actions\": np.array(f[\"actions\"]),\n",
    "            \"rewards\": np.array(f[\"rewards\"]),\n",
    "            \"costs\": np.array(f[\"costs\"]) if \"costs\" in f else np.zeros_like(f[\"rewards\"]),\n",
    "            \"terminals\": np.array(f[\"terminals\"]),\n",
    "            \"timeouts\": np.array(f[\"timeouts\"])\n",
    "        }\n",
    "    return data\n",
    "\n",
    "\n",
    "# ============================================================\n",
    "#   2. BUILD TRAJECTORIES\n",
    "# ============================================================\n",
    "\n",
    "def build_trajectories(data):\n",
    "    \"\"\"Slice transitions into trajectories + compute per-trajectory stats.\"\"\"\n",
    "    rewards = data[\"rewards\"]\n",
    "    costs = data[\"costs\"]\n",
    "    terminals = data[\"terminals\"]\n",
    "    timeouts = data[\"timeouts\"]\n",
    "    print(terminals, timeouts)\n",
    "\n",
    "    ends = np.where(np.logical_or(terminals, timeouts))[0] + 1\n",
    "    starts = np.concatenate(([0], ends[:-1]))\n",
    "\n",
    "    traj_rewards = np.array([rewards[s:e].sum() for s, e in zip(starts, ends)])\n",
    "    traj_costs   = np.array([costs[s:e].sum()   for s, e in zip(starts, ends)])\n",
    "    traj_lengths = np.array([e - s for s, e in zip(starts, ends)])\n",
    "\n",
    "    return {\n",
    "        \"starts\": starts,\n",
    "        \"ends\": ends,\n",
    "        \"traj_rewards\": traj_rewards,\n",
    "        \"traj_costs\": traj_costs,\n",
    "        \"traj_lengths\": traj_lengths,\n",
    "        \"n_traj\": len(traj_rewards)\n",
    "    }\n",
    "\n",
    "\n",
    "# ============================================================\n",
    "#   3. BASIC PLOTS (histograms)\n",
    "# ============================================================\n",
    "\n",
    "def plot_basic_stats(traj, bins=40):\n",
    "    \"\"\"Plots distributions of trajectory lengths, rewards, and costs.\"\"\"\n",
    "    fig, axs = plt.subplots(1, 3, figsize=(15,4))\n",
    "\n",
    "    sns.histplot(traj[\"traj_lengths\"], bins=bins, ax=axs[0])\n",
    "    axs[0].set_title(\"Trajectory Length Distribution\")\n",
    "\n",
    "    sns.histplot(traj[\"traj_rewards\"], bins=bins, ax=axs[1])\n",
    "    axs[1].set_title(\"Total Reward per Trajectory\")\n",
    "\n",
    "    sns.histplot(traj[\"traj_costs\"], bins=bins, ax=axs[2])\n",
    "    axs[2].set_title(\"Total Cost per Trajectory\")\n",
    "\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "\n",
    "# ============================================================\n",
    "#   4. COST THRESHOLD PLOT\n",
    "# ============================================================\n",
    "\n",
    "def plot_cost_reward_split(traj, cost_threshold):\n",
    "    \"\"\"Scatter reward vs cost with safe/unsafe threshold.\"\"\"\n",
    "    rewards = traj[\"traj_rewards\"]\n",
    "    costs = traj[\"traj_costs\"]\n",
    "\n",
    "    safe = costs <= cost_threshold\n",
    "    unsafe = ~safe\n",
    "    print(len(safe), len(unsafe))\n",
    "    plt.figure(figsize=(8,6))\n",
    "    plt.scatter(costs[safe], rewards[safe], color=\"green\", alpha=0.7, label=\"Safe\")\n",
    "    plt.scatter(costs[unsafe], rewards[unsafe], color=\"red\", alpha=0.7, label=\"Unsafe\")\n",
    "\n",
    "    plt.axvline(cost_threshold, color=\"black\", linestyle=\"--\", lw=2)\n",
    "\n",
    "    plt.xlabel(\"Total Cost\")\n",
    "    plt.ylabel(\"Total Reward\")\n",
    "    plt.title(\"Reward–Cost Distribution with Threshold\")\n",
    "    plt.legend()\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "\n",
    "# ============================================================\n",
    "#   5. TRAC TRAJECTORY SPLITTING\n",
    "# ============================================================\n",
    "\n",
    "def trac_split(traj, cost_threshold, x_perc=0.2, y_perc=0.2, delta=0.5):\n",
    "    \"\"\"Compute desirable & undesirable buckets and weights.\"\"\"\n",
    "    rewards = traj[\"traj_rewards\"]\n",
    "    costs = traj[\"traj_costs\"]\n",
    "\n",
    "    safe = costs <= cost_threshold\n",
    "    unsafe = ~safe\n",
    "\n",
    "    # safe reward ordering\n",
    "    safe_idx = np.where(safe)[0]\n",
    "    safe_rewards = rewards[safe]\n",
    "    order = np.argsort(safe_rewards)\n",
    "\n",
    "    n_safe = len(safe_idx)\n",
    "    n_top = max(1, int(n_safe * x_perc))\n",
    "    n_bottom = max(1, int(n_safe * y_perc))\n",
    "\n",
    "    top_idx = safe_idx[order[-n_top:]]\n",
    "    bottom_idx = safe_idx[order[:n_bottom]]\n",
    "    middle_idx = np.setdiff1d(safe_idx, np.concatenate([top_idx, bottom_idx]))\n",
    "\n",
    "    # initialize masks\n",
    "    desirable = np.zeros_like(rewards, dtype=bool)\n",
    "    undes_unsafe = unsafe.copy()\n",
    "    undes_safelow = np.zeros_like(rewards, dtype=bool)\n",
    "    ignored = np.zeros_like(rewards, dtype=bool)\n",
    "\n",
    "    desirable[top_idx] = True\n",
    "    undes_safelow[bottom_idx] = True\n",
    "    ignored[middle_idx] = True\n",
    "\n",
    "    # weights\n",
    "    w_des = np.zeros_like(rewards, float)\n",
    "    w_uns_unsafe = np.zeros_like(rewards, float)\n",
    "    w_uns_safe = np.zeros_like(rewards, float)\n",
    "\n",
    "    # desirable weights\n",
    "    if len(top_idx) > 0:\n",
    "        r = rewards[top_idx]\n",
    "        rmin, rmax = r.min(), r.max()\n",
    "        if rmax > rmin:\n",
    "            w_des[top_idx] = (r - rmin) / (rmax - rmin) * (1 - delta) + delta\n",
    "        else:\n",
    "            w_des[top_idx] = 1.0\n",
    "\n",
    "    # unsafe = weight 1\n",
    "    w_uns_unsafe[undes_unsafe] = 1.0\n",
    "\n",
    "    # safe low-reward weights (reverse)\n",
    "    if len(bottom_idx) > 0:\n",
    "        r = rewards[bottom_idx]\n",
    "        rmin, rmax = r.min(), r.max()\n",
    "        if rmax > rmin:\n",
    "            w_uns_safe[bottom_idx] = (1 - (r - rmin)/(rmax - rmin))*(1-delta)+delta\n",
    "        else:\n",
    "            w_uns_safe[bottom_idx] = 1.0\n",
    "\n",
    "    return {\n",
    "        \"desirable\": desirable,\n",
    "        \"undesirable_unsafe\": undes_unsafe,\n",
    "        \"undesirable_safelow\": undes_safelow,\n",
    "        \"ignored\": ignored,\n",
    "        \"w_des\": w_des,\n",
    "        \"w_uns_unsafe\": w_uns_unsafe,\n",
    "        \"w_uns_safe\": w_uns_safe\n",
    "    }\n",
    "\n",
    "\n",
    "# ============================================================\n",
    "#   6. PLOT TRAC SPLIT (reward–cost)\n",
    "# ============================================================\n",
    "\n",
    "def plot_trac_split(traj, split, cost_threshold):\n",
    "    \"\"\"Scatter plot showing TraC desirable/undesirable split.\"\"\"\n",
    "    rewards = traj[\"traj_rewards\"]\n",
    "    costs = traj[\"traj_costs\"]\n",
    "\n",
    "    plt.figure(figsize=(8,6))\n",
    "    plt.scatter(costs[split[\"desirable\"]], rewards[split[\"desirable\"]],\n",
    "                color=\"green\", alpha=0.8, label=\"Desirable\")\n",
    "    plt.scatter(costs[split[\"undesirable_safelow\"]], rewards[split[\"undesirable_safelow\"]],\n",
    "                color=\"orange\", alpha=0.7, label=\"Undesirable (low safe)\")\n",
    "    plt.scatter(costs[split[\"undesirable_unsafe\"]], rewards[split[\"undesirable_unsafe\"]],\n",
    "                color=\"red\", alpha=0.7, label=\"Undesirable (unsafe)\")\n",
    "\n",
    "    if split[\"ignored\"].sum() > 0:\n",
    "        plt.scatter(costs[split[\"ignored\"]], rewards[split[\"ignored\"]],\n",
    "                    color=\"gray\", alpha=0.3, label=\"Ignored safe\")\n",
    "\n",
    "    plt.axvline(cost_threshold, color=\"black\", linestyle=\"--\", lw=2)\n",
    "\n",
    "    plt.xlabel(\"Total Cost\")\n",
    "    plt.ylabel(\"Total Reward\")\n",
    "    plt.title(\"TraC Desirable/Undesirable Trajectory Split\")\n",
    "    plt.legend()\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "\n",
    "# ============================================================\n",
    "#   7. WEIGHT HISTOGRAMS\n",
    "# ============================================================\n",
    "\n",
    "def plot_weight_histograms(split):\n",
    "    \"\"\"Plot weight distributions for all trajectory categories.\"\"\"\n",
    "    fig, axs = plt.subplots(1,3, figsize=(14,4), sharey=True)\n",
    "\n",
    "    sns.histplot(split[\"w_des\"][split[\"desirable\"]], bins=20, ax=axs[0], color=\"green\")\n",
    "    axs[0].set_title(\"Desirable Weights\")\n",
    "\n",
    "    sns.histplot(split[\"w_uns_safe\"][split[\"undesirable_safelow\"]], bins=20, ax=axs[1], color=\"orange\")\n",
    "    axs[1].set_title(\"Undesirable (Safe Low) Weights\")\n",
    "\n",
    "    sns.histplot(split[\"w_uns_unsafe\"][split[\"undesirable_unsafe\"]], bins=20, ax=axs[2], color=\"red\")\n",
    "    axs[2].set_title(\"Undesirable (Unsafe) Weights\")\n",
    "\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n"
   ]
  },
